# ===========================================
# TimeLock Backend - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
# Option 1: Use connection string (recommended for NeonDB/cloud)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Option 2: Use individual parameters (for local development)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=timelock
# DATABASE_SSL=false

# ===========================================
# Security Configuration (CRITICAL!)
# ===========================================
# JWT_SECRET: Used for signing authentication tokens
# REQUIREMENTS:
#   - Minimum 32 characters in production
#   - Must be unique and random
#   - Generate with: openssl rand -hex 32
JWT_SECRET=your_32_character_or_longer_secret_here

# JWT_EXPIRES: Token expiration time
# Examples: 15m, 1h, 1d, 7d
JWT_EXPIRES=1d

# WALLET_ENCRYPTION_SECRET: Used for encrypting internal wallet private keys
# REQUIREMENTS:
#   - Minimum 32 characters in production
#   - Must be unique and random
#   - Generate with: openssl rand -hex 32
# WARNING: If you change this, existing encrypted wallets will be unreadable!
WALLET_ENCRYPTION_SECRET=your_32_character_or_longer_secret_here

# COOKIE_SECRET: Used for signing cookies (optional, defaults to JWT_SECRET)
# COOKIE_SECRET=your_cookie_secret_here

# ===========================================
# Application Configuration
# ===========================================
# Server port
PORT=3011

# Environment: development | production
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3010

# ===========================================
# Blockchain Configuration
# ===========================================
# Polygon Mainnet Factory Address (set after deployment)
# FACTORY_ADDRESS_POLYGON=0x...

# RPC URLs (optional, defaults provided)
# POLYGON_RPC_URL=https://polygon-rpc.com
# ETHEREUM_RPC_URL=https://eth.llamarpc.com

# ===========================================
# Email Configuration (for verification)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@timelock.app
