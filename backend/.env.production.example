# ============================================================
# TimeLock Backend — production environment
# ============================================================
# Copy to `.env` on the backend machine (NOT committed to git).
# Generate strong secrets with: openssl rand -hex 32

NODE_ENV=production
PORT=3011

# ---------- Database (self-hosted Postgres on its own machine) ----------
# Use the private IP if the machines share a VPN/private network.
DATABASE_URL=postgresql://timelock_user:STRONG_PASSWORD@10.0.0.42:5432/timelock?sslmode=disable
# If your Postgres uses self-signed TLS:
# DATABASE_URL=postgresql://timelock_user:STRONG_PASSWORD@db.internal:5432/timelock?sslmode=require
# DATABASE_SSL=true

# ---------- Security ----------
# JWT_SECRET: minimum 32 chars, unique. openssl rand -hex 32
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32
JWT_EXPIRES=7d

# Used to encrypt embedded wallet private keys server-side (legacy flow).
WALLET_ENCRYPTION_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# Optional: signs the cookie. Defaults to JWT_SECRET if absent.
COOKIE_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# ---------- CORS / cookies (cross-domain setup) ----------
# Comma-separated list of allowed origins. Front lives on its own subdomain
# in this deployment.
FRONTEND_URLS=https://timelock.app,https://www.timelock.app

# Optional: share the JWT cookie between subdomains. Leave blank for host-only
# cookie (api.timelock.app keeps it for itself, which is fine since the
# browser sends it via SameSite=None+Secure anyway).
# COOKIE_DOMAIN=.timelock.app

# ---------- Blockchain ----------
# Optional: bootstrap factory addresses if the DB has none. Once a deploy
# happens via /deploy, the DB value takes precedence.
# FACTORY_ADDRESS_POLYGON=0x...
# FACTORY_ADDRESS_AMOY=0x...
# FILE_LOCK_FACTORY_POLYGON=0x...
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ---------- Pinata (server-side, e.g. ipfs.service unpin) ----------
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ---------- Email (optional, for verification) ----------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@timelock.app
