# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3011/api

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Etherscan API v2 key (used to fetch native POL balance + ERC20 balances for
# embedded wallets — wagmi/RPC is used for external wallets).
# Get a free key at https://etherscan.io/myapikey
NEXT_PUBLIC_ETHERSCAN_API_KEY=your_etherscan_v2_key_here

# Pinata JWT (used client-side to pin encrypted files to IPFS for the
# "Files Blockchain" feature). Create at https://app.pinata.cloud/keys
# Use the JWT, NOT the legacy API_KEY/SECRET_KEY pair.
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_here
# Optional: custom dedicated gateway (https://YOUR-NAME.mypinata.cloud).
# Leave commented to use the public gateway.
# NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Optional: override the factory address (only useful for local dev). In normal
# operation the address is read from the backend (factory_deployments table).
# NEXT_PUBLIC_CRYPTO_TIMELOCK_FACTORY_POLYGON=0x...
